# ============================================
# ON-PREMISE STACK - Variables d'environnement
# ============================================
# Renommer en .env et adapter

# ---- Domaine ----
# Pour test local: utiliser un domaine .local résolu via /etc/hosts
DOMAIN=onprem.local
ACME_EMAIL=admin@onprem.local

# Pour Let's Encrypt staging (recommandé en VM/test)
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# Pour PROD: https://acme-v02.api.letsencrypt.org/directory

# ---- Traefik dashboard ----
# htpasswd -nb admin 'changeme' -> remplacer (échapper $ en $$)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$abcd1234$$XXXXXXXXXXXXXXXXXX

# ---- Keycloak ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMe_Admin_2025!
KC_DB_PASSWORD=ChangeMe_KCDB_2025!

# ---- Nextcloud ----
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=ChangeMe_NC_2025!
NEXTCLOUD_DB_PASSWORD=ChangeMe_NCDB_2025!
NEXTCLOUD_REDIS_PASSWORD=ChangeMe_Redis_2025!

# Chemin NAS (montage NFS/CIFS sur l'hôte)
NAS_DATA_PATH=/mnt/nas/nextcloud-data

# ---- Grafana ----
GRAFANA_ADMIN_PASSWORD=ChangeMe_Grafana_2025!

# ---- WireGuard ----
WG_SERVERURL=vpn.onprem.local
WG_PEERS=3
