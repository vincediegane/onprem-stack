{
  "title": "OnPrem Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    { "type": "stat", "title": "CPU usage (%)", "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)" }], "gridPos":{"x":0,"y":0,"w":6,"h":4} },
    { "type": "stat", "title": "Memory used (%)", "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100" }], "gridPos":{"x":6,"y":0,"w":6,"h":4} },
    { "type": "timeseries", "title": "Container CPU", "targets": [{ "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=''}[5m]))" }], "gridPos":{"x":0,"y":4,"w":12,"h":8} },
    { "type": "timeseries", "title": "HTTP requests (Traefik)", "targets": [{ "expr": "sum by (code) (rate(traefik_service_requests_total[5m]))" }], "gridPos":{"x":0,"y":12,"w":12,"h":8} }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
